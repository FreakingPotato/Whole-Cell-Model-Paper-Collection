      <data key="d23">../graphify_corpus/papers/WCM-022.md</data>
      <data key="d5">0</data>
    </node>
    <node id="WCM-023">
      <data key="d0">Integrative modeling of JCVI-Syn3A nucleoids with a modular approach</data>
      <data key="d1">paper</data>
      <data key="d2">graphify_corpus/papers/WCM-023.md</data>
      <data key="d3">L1</data>
      <data key="d6">10.1016/j.crstbi.2023.100121</data>
      <data key="d7">2023</data>
      <data key="d8">Current Research in Structural Biology</data>
      <data key="d9">Goodsell 2023</data>
      <data key="d10">Hybrid architectures</data>
      <data key="d11">JCVI-syn3A / minimal cell</data>
      <data key="d12">JCVI minimal cell</data>
      <data key="d13">landing_page_only</data>
      <data key="d14" />
      <data key="d15" />
      <data key="d16">https://doi.org/10.1016/j.crstbi.2023.100121</data>
      <data key="d17">A lattice-based method is presented for creating 3D models of entire bacterial nucleoids integrating ultrastructural information cryoelectron tomography, genomic and proteomic data, and experimental atomic structures of biomolecules and assemblies. The method is used to generate models of the minimal genome bacterium JCVI-Syn3A, producing a series of models that test hypotheses about transcription, condensation, and overall distribution of the genome. Lattice models are also used to generate atomic models of an entire JCVI-Syn3A cell.</data>
      <data key="d18">A lattice-based method is presented for creating 3D models of entire bacterial nucleoids integrating ultrastructural information cryoelectron tomography, genomic and proteomic data, and experimental atomic structures of biomolecules and assemblies.</data>
      <data key="d19">Establishes or extends the minimal-cell experimental and conceptual foundation used by later whole-cell models.</data>
