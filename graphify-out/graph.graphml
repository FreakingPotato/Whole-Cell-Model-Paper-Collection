      <data key="d11">Bacillus subtilis</data>
      <data key="d12">General bacteria</data>
      <data key="d13">downloaded</data>
      <data key="d14">WCM-036_2021_DNA-loop-extruding_SMC_complexes_can_traverse_one_another_in_vivo.pdf</data>
